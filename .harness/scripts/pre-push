#!/usr/bin/env bash
# implementation-harness pre-push hook — refuses pushes made from inside a harness AGENT session.
#
# WHY: in the IN-PLACE loop variant the builder works DIRECTLY on `main` and must NOT push — the loop
# is the sole pusher (it runs the local DoD + the independent audit, pushes, then gates on CI and
# reverts on red). A builder that pushes its own commits bypasses that whole gate: the work lands on
# `main` ungated, red CI is never reverted (the loop only reverts commits IT pushed), and the loop's
# next diff comes back empty (origin/main already advanced) — recorded as a phantom `empty-diff`
# soft-fail. This is a P5 violation ("the loop owns pushes"); this hook enforces P5 mechanically,
# because the prompt's "do NOT push" is only advisory and cheap models ignore it (often because the
# user's own global git guidance says "always push after committing").
#
# HOW IT'S SCOPED (this is the important part): the loop does NOT persist `core.hooksPath`. Instead
# `run_claude` points the AGENT's git at this hooks dir for the duration of the agent subprocess only,
# via `GIT_CONFIG_*` env vars (see loop.in-place.sh). So this hook fires ONLY for the agent's git —
# the loop's own pushes and any human `git push` use the repo's normal hooks (husky/pre-commit stay
# intact and never see this file). The `HARNESS_AGENT` guard below is belt-and-suspenders: even if
# this hook were ever wired persistently, it refuses ONLY agent-marked pushes, never a human's.
#
# The WORKTREE variant deliberately does NOT activate this: there the builder works in an isolated
# worktree on a feature branch and is REQUIRED to push that branch (CI gates the branch; the loop
# fast-forwards `main` only on green). So it never sets HARNESS_AGENT and this hook stays dormant.

if [ -n "${HARNESS_AGENT:-}" ]; then
  echo "" >&2
  echo "✋ implementation-harness: build/audit agents must NOT push." >&2
  echo "   The loop is the sole pusher — it runs your checks, audits, pushes, and gates CI for you." >&2
  echo "" >&2
  echo "   Do this instead:" >&2
  echo "     1. run your project's Definition-of-Done checks locally and get them fully green," >&2
  echo "     2. commit your work as ONE commit (do NOT push; amend to iterate — never stack commits)," >&2
  echo "     3. write 'done <TASK>' to .harness/worklog/.result and stop." >&2
  echo "   Do NOT try to bypass this (no 'git push --no-verify', no unsetting HARNESS_AGENT)." >&2
  echo "" >&2
  exit 1
fi
exit 0
