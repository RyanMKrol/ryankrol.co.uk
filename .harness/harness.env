# .harness/harness.env — config for the in-place Ralph loop (sourced by loop.sh).
#
# Precedence:  real environment  >  this file  >  loop.sh built-in default
# (the `: "${VAR:=…}"` form only assigns when VAR is unset).

# ─── Model (COLD-START FLOOR — cheapest tier; the policy tunes UP from here) ──
# Tasks no longer carry per-task model/effort; the policy picks each task's start tier from
# facets + the outcomes ledger, cold-starting at this floor. Pin the FULL id (the bare alias drifts).
: "${MODEL:=claude-sonnet-5}"
: "${EFFORT:=low}"        # low|medium|high|xhigh|max — cheapest by default (bias-cheap; the ladder escalates)

# ─── Caps & cadence ──────────────────────────────────────────────────────────
: "${MAX_ATTEMPTS:=2}"     # soft failures per rung before escalating (global ladder is fine-grained, so fewer tries per rung bounds the attempt budget)
: "${MAX_ITERS:=100}"      # global iteration backstop per run
: "${WAIT_SECONDS:=30}"    # backoff between retries / CI polls
: "${CI_TIMEOUT:=1200}"    # max seconds to wait for a CI run

# ─── CI gate ─────────────────────────────────────────────────────────────────
: "${CI_WORKFLOW:=CI}"     # MUST equal `name:` in .github/workflows/ci.yml
: "${REQUIRE_CI:=1}"       # 1 = never mark a task done without green CI on main
: "${MAIN_BRANCH:=main}"

# ─── Local Definition-of-Done gate (cheap, runs BEFORE the paid audit) ────────
# The loop's structural_checks runs this in the checkout before the blocking audit, so a build that
# doesn't compile never reaches the (paid) auditor. Mirror CI's checks.
# This is a Next.js (pages-router) JavaScript app. ESLint (flat config, eslint-config-next) + a Jest
# unit suite are now set up and run headless, so the DoD is lint + tests + a clean production build.
: "${LOCAL_DOD:=npm run lint && npm test && npm run build}"

# ─── Claude usage-limit backoff (pause + cold re-attempt) ────────────────────
# When `claude` hits the usage limit, the loop sleeps and RE-ATTEMPTS the same task COLD (not
# counted as a failure — every attempt is a fresh cold pass). Two paths: if Claude's own message
# has a parseable reset time, sleep exactly until then + RL_BUFFER (capped at RL_BACKOFF_MAX — a
# known reset can legitimately be hours away); otherwise blind exponential backoff starting at
# RL_BACKOFF_MIN and capped at RL_EXP_MAX.
: "${RL_BACKOFF_MIN:=300}"     # exponential-fallback first backoff: 5 min
: "${RL_EXP_MAX:=3600}"        # exponential-fallback cap: 1h (UNKNOWN-reset path only)
: "${RL_BACKOFF_MAX:=18000}"   # cap for a PARSED reset wait: ~5h (known reset can be hours away)
: "${RL_BUFFER:=300}"          # resume this many secs AFTER a parsed reset (5-min cushion)

# ─── Push cooldown (pace pushes so a task burst can't trip Vercel's build rate limit) ─────────
# On 2026-07-02, ~10 task commits within under an hour tripped Vercel's Hobby-tier build rate
# limit, silently rejecting builds for ~10h with no alert (see .harness/CLAUDE.md's dated incident
# log). throttled_push() (loop.sh) enforces a minimum wall-clock gap since the previous SUCCESSFUL
# push before issuing the next one — a fast run of small tasks sleeps out the remainder instead of
# bursting; a project completing one task every few hours never notices this. State survives a
# loop/supervise restart (persisted to gitignored .harness/worklog/.last-push-ts, not just an
# in-process variable).
: "${PUSH_COOLDOWN_SECONDS:=300}"  # min seconds between successful pushes to main (5 min default — err a bit high since the failure mode is silent)

# ─── Dirty-tree self-heal on unattended startup ──────────────────────────────
# The in-place loop cold-resets the working tree between attempts, so a dirty tree at startup
# normally makes it refuse to run (protects real human edits). But this checkout is OWNED by the
# loop, and a dirty tree here is almost always ORPHANED partial work from a previous attempt killed
# mid-build (e.g. a usage-limit interrupt) — not human work — which would otherwise permanently
# block every future unattended cycle. 1 = auto-stash (recoverable via `git stash list`) + hard-reset
# to origin/main at startup instead of refusing.
: "${LOOP_AUTORESET:=1}"

# NOTE: jq + gh are required (brew install jq gh; gh auth login).

# After each task integrates (CI green), refresh the running product. This site deploys via Vercel,
# which auto-builds + deploys on every push to `main` — so there is nothing to rebuild or restart
# locally. The hook is a no-op; see .harness/integrate.sh.
: "${INTEGRATE_HOOK:=bash .harness/integrate.sh}"
