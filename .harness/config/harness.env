# .harness/config/harness.env вЂ” config for the in-place Ralph loop (sourced by scripts/loop.sh).
#
# Precedence:  real environment  >  this file  >  loop.sh built-in default
# (the `: "${VAR:=вЂ¦}"` form only assigns when VAR is unset).

# в”Ђв”Ђв”Ђ Model (COLD-START FLOOR вЂ” cheapest tier; the policy tunes UP from here) в”Ђв”Ђ
# Tasks no longer carry per-task model/effort; the policy picks each task's start tier from
# facets + the outcomes ledger, cold-starting at this floor. Pin the FULL id where one exists
# distinct from the alias (the bare alias drifts) вЂ” EXCEPT Haiku 4.5, where we deliberately use
# the bare alias `claude-haiku-4-5` to match the sibling `local-jobs` harness's convention.
: "${MODEL:=claude-haiku-4-5}"
: "${EFFORT:=}"           # empty = effort-less floor (Haiku 4.5 has no effort param); the ladder escalates from here

# в”Ђв”Ђв”Ђ Caps & cadence в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
: "${MAX_ATTEMPTS:=2}"     # soft failures per rung before escalating (global ladder is fine-grained, so fewer tries per rung bounds the attempt budget)
: "${MAX_ITERS:=100}"      # global iteration backstop per run
: "${WAIT_SECONDS:=30}"    # backoff between retries / CI polls
: "${CI_TIMEOUT:=1200}"    # max seconds to wait for a CI run

# в”Ђв”Ђв”Ђ CI gate в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
: "${CI_WORKFLOW:=CI}"     # MUST equal `name:` in .github/workflows/ci.yml
: "${REQUIRE_CI:=1}"       # 1 = never mark a task done without green CI on main
: "${MAIN_BRANCH:=main}"

# в”Ђв”Ђв”Ђ Local Definition-of-Done gate (cheap, runs BEFORE the paid audit) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# The loop's structural_checks runs this in the checkout before the blocking audit, so a build that
# doesn't compile never reaches the (paid) auditor. Mirror CI's checks.
# This is a Next.js (pages-router) JavaScript app. ESLint (flat config, eslint-config-next) + a Jest
# unit suite are now set up and run headless, so the DoD is lint + tests + a clean production build.
: "${LOCAL_DOD:=npm run lint && npm test && npm run build}"

# в”Ђв”Ђв”Ђ Claude usage-limit backoff (pause + cold re-attempt) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# When `claude` hits the usage limit, the loop sleeps and RE-ATTEMPTS the same task COLD (not
# counted as a failure вЂ” every attempt is a fresh cold pass). Two paths: if Claude's own message
# has a parseable reset time, sleep exactly until then + RL_BUFFER (capped at RL_BACKOFF_MAX вЂ” a
# known reset can legitimately be hours away); otherwise blind exponential backoff starting at
# RL_BACKOFF_MIN and capped at RL_EXP_MAX.
: "${RL_BACKOFF_MIN:=300}"     # exponential-fallback first backoff: 5 min
: "${RL_EXP_MAX:=3600}"        # exponential-fallback cap: 1h (UNKNOWN-reset path only)
: "${RL_BACKOFF_MAX:=18000}"   # cap for a PARSED reset wait: ~5h (known reset can be hours away)
: "${RL_BUFFER:=300}"          # resume this many secs AFTER a parsed reset (5-min cushion)

# в”Ђв”Ђв”Ђ Push cooldown (pace pushes so a task burst can't trip Vercel's build rate limit) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# On 2026-07-02, ~10 task commits within under an hour tripped Vercel's Hobby-tier build rate
# limit, silently rejecting builds for ~10h with no alert (see .harness/CLAUDE.md's dated incident
# log). throttled_push() (loop.sh) enforces a minimum wall-clock gap since the previous SUCCESSFUL
# push before issuing the next one вЂ” a fast run of small tasks sleeps out the remainder instead of
# bursting; a project completing one task every few hours never notices this. State survives a
# loop/supervise restart (persisted to gitignored .harness/worklog/.last-push-ts, not just an
# in-process variable).
#
# DISABLED as of 2026-07-03: Vercel's Git integration for this project is fully disconnected
# (`vercel git disconnect` вЂ” see root CLAUDE.md's "Deploying" section), so pushing to `main` no
# longer triggers ANY Vercel deployment, successful or rate-limited. A push burst has nothing left
# to trip. Set back to a positive value (300 is what caused the original incident to stop
# recurring) if `vercel git connect` is ever run again to restore auto-deploy-on-push.
: "${PUSH_COOLDOWN_SECONDS:=0}"  # min seconds between successful pushes to main вЂ” 0 while Vercel Git integration is disconnected (nothing to pace against); restore to 300 if Git integration is reconnected

# в”Ђв”Ђв”Ђ Dirty-tree self-heal on unattended startup в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# The in-place loop cold-resets the working tree between attempts, so a dirty tree at startup
# normally makes it refuse to run (protects real human edits). But this checkout is OWNED by the
# loop, and a dirty tree here is almost always ORPHANED partial work from a previous attempt killed
# mid-build (e.g. a usage-limit interrupt) вЂ” not human work вЂ” which would otherwise permanently
# block every future unattended cycle. 1 = auto-stash (recoverable via `git stash list`) + hard-reset
# to origin/main at startup instead of refusing.
: "${LOOP_AUTORESET:=1}"

# NOTE: jq + gh are required (brew install jq gh; gh auth login).


# в•ђв•ђв•ђ Canonical 1.24.0 knobs (added during the flatв†’canonical adoption) в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# All OPTIONAL overrides вЂ” each has the SAME built-in default in the mechanism (${VAR:-default}),
# so these change no behavior; they just make the override points explicit and keep the next
# `/upgrade-harness` clean. Annotated where a knob is inert for THIS project (in-place variant,
# no visual-verification hook).

# в”Ђв”Ђв”Ђ Integrate hook в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Command run AFTER each task integrates (CI green). Deploy is handled instead by the on-drained
# lifecycle hook (custom/hooks/on-drained.sh), so this stays empty (the old no-op integrate.sh
# was retired in the canonical migration).
: "${INTEGRATE_HOOK:=}"

# в”Ђв”Ђв”Ђ Sync primary checkout when done (WORKTREE VARIANT ONLY вЂ” inert here) в”Ђв”Ђв”Ђв”Ђв”Ђ
# No effect on the in-place variant (this repo), which already works directly on main.
: "${SYNC_PRIMARY_ON_DONE:=1}"

# в”Ђв”Ђв”Ђ Visual-verification hook (ON вЂ” hermetic Playwright screenshots) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Captures the app's visual output for the auditor to eyeball. `scripts/visual-check.mjs` starts a
# hermetic `next start` (all /api/* served from synthetic fixtures, external images placeholdered),
# screenshots every page to scripts/visual-out/, and the auditor/builder Reads the PNGs. This exists
# because T273 (Markdown that never rendered) passed lint/tests/build вЂ” a text diff can't see pixels.
# Back-compat: UI_VERIFY_HOOK is honoured if VISUAL_VERIFY_HOOK is unset.
: "${VISUAL_VERIFY_HOOK:=${UI_VERIFY_HOOK:-node scripts/visual-check.mjs}}"
: "${VISUAL_VERIFY_WORKTYPES:=component style}"          # inherently-visual work-types fire on any layer
: "${VISUAL_VERIFY_LAYERS:=page style ui}"               # this project's visual layers auto-fire (unless work-type skipped)
: "${VISUAL_VERIFY_SKIP_WORKTYPES:=docs config logging}" # never auto-fire on these

# в”Ђв”Ђв”Ђ Extra scope exemptions в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Space-separated extra path prefixes structural_checks always allows (beyond worklog + tests).
# Empty = the scope gate stays fully strict.
# `scripts/` holds the visual-check tooling (a LIVING ARTIFACT вЂ” a UI task legitimately updates its
# PAGES/fixtures when the UI surface changes), so exempt it rather than forcing every UI task to list it.
: "${SCOPE_EXEMPT_GLOBS:=scripts/}"

# в”Ђв”Ђв”Ђ Dashboard в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Port for `npm run harness:dashboard`; FETCH_SECONDS>0 makes it `git fetch` on that interval so
# its freshness badge can't silently lag origin. 0 = report data age only, never fetch.
: "${HARNESS_DASHBOARD_PORT:=4790}"
: "${HARNESS_DASHBOARD_FETCH_SECONDS:=0}"

# в”Ђв”Ђв”Ђ Rate-limit: audit-path poll + give-up budget в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Complements the RL_BACKOFF_* knobs above. RL_POLL = how often the (rarer) AUDIT path polls for a
# quota reset while limited; RL_MAX_WAIT = give up + exit 5 (hand back to supervise) after this
# long still limited (~6h), so the reset is picked up next cycle.
: "${RL_POLL:=900}"
: "${RL_MAX_WAIT:=21600}"

# в”Ђв”Ђв”Ђ supervise.sh retry cadence в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Short relaunch interval used INSTEAD of the normal cadence after the loop gives up rate-limited
# (exit 5), so a quota reset is picked up within ~this long.
: "${RETRY_INTERVAL:=900}"

# в”Ђв”Ђв”Ђ Escalation-ladder resume across a loop.sh restart в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# A leftover worklog/.current.json heartbeat at process start (heartbeat_clear() runs only at a
# genuine terminal task outcome, not on every exit) is treated as a resumable mid-climb interruption
# rather than a fresh cold start вЂ” UNLESS it's older than this cap, in which case it's ignored as
# stale and the ladder cold-starts as before. Matches RL_MAX_WAIT's order of magnitude (~6h).
: "${LOOP_HEARTBEAT_RESUME_MAX_AGE:=21600}"
# One-shot escape hatch: set to 1 for a single run to force a clean, cold escalation-ladder restart,
# ignoring any leftover heartbeat (e.g. after a deliberate human intervention that wants a fresh start).
: "${LOOP_IGNORE_HEARTBEAT:=}"
